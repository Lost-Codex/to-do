// This is your Prisma schema file
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma/client"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id       String @id @default(uuid())
  name     String
  sku      String @unique
  quantity Int    @default(0)
  zone     String
}